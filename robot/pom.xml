<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.cryptotrade</groupId>
        <artifactId>crypto-exchange</artifactId>
        <version>1.0.0</version>
    </parent>

    <artifactId>robot</artifactId>
    <packaging>jar</packaging>
    <name>Robot Module</name>
    <description>交易机器人模块 - 网格交易、趋势跟踪、反向策略等</description>

    <dependencies>
        <!-- Common Module -->
        <dependency>
            <groupId>com.cryptotrade</groupId>
            <artifactId>common</artifactId>
        </dependency>

        <!-- Spring Boot Data JPA -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
        </dependency>

        <!-- Spring Boot Web -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!-- Redis -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-redis</artifactId>
        </dependency>

        <!-- Swagger -->
        <dependency>
            <groupId>io.springfox</groupId>
            <artifactId>springfox-boot-starter</artifactId>
        </dependency>

        <!-- JSON Processing -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
        </dependency>

        <!-- Spot Trading Module (for SpotOrderService and MarketDataService) -->
        <dependency>
            <groupId>com.cryptotrade</groupId>
            <artifactId>spot-trading</artifactId>
        </dependency>

        <!-- Wallet Module (for balance management) -->
        <dependency>
            <groupId>com.cryptotrade</groupId>
            <artifactId>wallet</artifactId>
        </dependency>

        <!-- Futures USDT Module (for FuturesOrderService and FuturesMarketDataService) -->
        <dependency>
            <groupId>com.cryptotrade</groupId>
            <artifactId>futures-usdt</artifactId>
        </dependency>

        <!-- Futures Coin Module (for CoinFuturesOrderService and CoinFuturesMarketDataService) -->
        <dependency>
            <groupId>com.cryptotrade</groupId>
            <artifactId>futures-coin</artifactId>
        </dependency>

        <!-- MySQL Driver -->
        <dependency>
            <groupId>mysql</groupId>
            <artifactId>mysql-connector-java</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <mainClass>com.cryptotrade.robot.RobotApplication</mainClass>
                    <classifier>exec</classifier>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>

